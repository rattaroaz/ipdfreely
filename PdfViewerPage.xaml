<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="ipdfreely.PdfViewerPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="PDF">

    <Grid Padding="8" RowDefinitions="Auto,*" RowSpacing="8">
        <HorizontalStackLayout Grid.Row="0" Spacing="8">
            <Button Clicked="OnOpenClicked" Text="Open" />
            <Button Clicked="OnSaveClicked" Text="Save PDF" />
            <Button
                x:Name="AddTextButton"
                Clicked="OnAddTextClicked"
                Text="Add text" />
            <Button Clicked="OnToggleFieldsClicked" x:Name="ToggleFieldsButton" Text="Hide fields" />
            <Label
                x:Name="StatusLabel"
                LineBreakMode="TailTruncation"
                MaxLines="2"
                VerticalOptions="Center"
                VerticalTextAlignment="Center" />
        </HorizontalStackLayout>

        <Grid Grid.Row="1" RowDefinitions="*,Auto" RowSpacing="8">
            <ScrollView x:Name="PageScroll" Grid.Row="0">
                <Grid x:Name="ZoomHost" BackgroundColor="Transparent">
                    <VerticalStackLayout
                        x:Name="PagesLayout"
                        Padding="0,0,0,24"
                        Spacing="16" />
                </Grid>
            </ScrollView>

            <ScrollView
                Grid.Row="1"
                HeightRequest="112"
                HorizontalScrollBarVisibility="Always"
                Orientation="Horizontal">
                <HorizontalStackLayout
                    x:Name="ThumbsLayout"
                    Padding="4"
                    Spacing="8" />
            </ScrollView>
        </Grid>
    </Grid>
</ContentPage>
