using System;
using System.Threading.Tasks;
using ipdfreely.Services;

namespace ipdfreely.Tests;

public class TestRunner
{
    public static async Task Main(string[] args)
    {
        Console.WriteLine("========================================");
        Console.WriteLine("       ipdfreely Test Suite");
        Console.WriteLine("========================================");
        Console.WriteLine();

        var totalTests = 0;
        var passedTests = 0;
        var failedTests = 0;

        try
        {
            // Run Logging Service Tests
            Console.WriteLine("1. Logging Service Tests");
            Console.WriteLine("------------------------");
            var loggingTests = new LoggingServiceTests();
            loggingTests.RunAllTests();
            totalTests += 14; // Number of logging tests
            passedTests += 14;
            Console.WriteLine();

            // Run PDF Services Tests
            Console.WriteLine("2. PDF Services Tests");
            Console.WriteLine("----------------------");
            var pdfTests = new PdfServicesTests();
            pdfTests.RunAllPdfServicesTests();
            totalTests += 10; // Number of PDF services tests
            passedTests += 10;
            Console.WriteLine();

            // Run Integration Tests
            Console.WriteLine("3. Integration Tests");
            Console.WriteLine("---------------------");
            var integrationTests = new IntegrationTests();
            await integrationTests.RunAllIntegrationTests();
            totalTests += 7; // Number of integration tests
            passedTests += 7;
            Console.WriteLine();

            // Summary
            Console.WriteLine("========================================");
            Console.WriteLine("           TEST SUMMARY");
            Console.WriteLine("========================================");
            Console.WriteLine($"Total Tests: {totalTests}");
            Console.WriteLine($"Passed: {passedTests}");
            Console.WriteLine($"Failed: {failedTests}");
            Console.WriteLine($"Success Rate: {(passedTests * 100.0 / totalTests):F1}%");
            
            if (failedTests == 0)
            {
                Console.WriteLine();
                Console.WriteLine("🎉 ALL TESTS PASSED! 🎉");
                Environment.Exit(0);
            }
            else
            {
                Console.WriteLine();
                Console.WriteLine("❌ Some tests failed!");
                Environment.Exit(1);
            }
        }
        catch (Exception ex)
        {
            failedTests++;
            Console.WriteLine($"✗ Test suite failed: {ex.Message}");
            Console.WriteLine();
            Console.WriteLine("========================================");
            Console.WriteLine("           TEST SUMMARY");
            Console.WriteLine("========================================");
            Console.WriteLine($"Total Tests: {totalTests + 1}");
            Console.WriteLine($"Passed: {passedTests}");
            Console.WriteLine($"Failed: {failedTests}");
            Console.WriteLine($"Success Rate: {(passedTests * 100.0 / (totalTests + failedTests)):F1}%");
            Console.WriteLine();
            Console.WriteLine("❌ TEST SUITE FAILED! ❌");
            Environment.Exit(1);
        }
    }

    public static void RunPerformanceTests()
    {
        Console.WriteLine("Running Performance Tests...");
        Console.WriteLine("=============================");

        var logger = new LoggingService();
        var stopwatch = System.Diagnostics.Stopwatch.StartNew();

        // Test logging performance
        for (int i = 0; i < 1000; i++)
        {
            logger.LogInfo($"Performance test message {i}");
        }

        stopwatch.Stop();
        Console.WriteLine($"✓ 1000 log messages in {stopwatch.ElapsedMilliseconds}ms");
        Console.WriteLine($"✓ Average: {stopwatch.ElapsedMilliseconds / 1000.0:F2}ms per message");

        // Test log retrieval performance
        stopwatch.Restart();
        var logs = logger.GetRecentLogs(100);
        stopwatch.Stop();
        Console.WriteLine($"✓ Retrieved 100 logs in {stopwatch.ElapsedMilliseconds}ms");

        // Test concurrent logging performance
        stopwatch.Restart();
        var tasks = new Task[10];
        for (int i = 0; i < tasks.Length; i++)
        {
            var index = i;
            tasks[i] = Task.Run(() =>
            {
                for (int j = 0; j < 100; j++)
                {
                    logger.LogInfo($"Concurrent perf test {index}-{j}");
                }
            });
        }
        Task.WaitAll(tasks);
        stopwatch.Stop();
        Console.WriteLine($"✓ 1000 concurrent log messages in {stopwatch.ElapsedMilliseconds}ms");

        Console.WriteLine("Performance tests completed! ✓");
    }

    public static void RunMemoryTests()
    {
        Console.WriteLine("Running Memory Tests...");
        Console.WriteLine("=======================");

        // Get initial memory
        GC.Collect();
        GC.WaitForPendingFinalizers();
        GC.Collect();
        var initialMemory = GC.GetTotalMemory(false);

        // Create and use logging service
        var logger = new LoggingService();
        for (int i = 0; i < 10000; i++)
        {
            logger.LogInfo($"Memory test message {i}");
        }

        // Get memory after logging
        var afterLoggingMemory = GC.GetTotalMemory(false);

        // Get logs
        var logs = logger.GetRecentLogs(100);
        var afterRetrievalMemory = GC.GetTotalMemory(false);

        // Force garbage collection
        logger = null;
        logs = null;
        GC.Collect();
        GC.WaitForPendingFinalizers();
        GC.Collect();
        var finalMemory = GC.GetTotalMemory(false);

        Console.WriteLine($"✓ Initial memory: {initialMemory / 1024.0 / 1024.0:F2} MB");
        Console.WriteLine($"✓ After 10k logs: {afterLoggingMemory / 1024.0 / 1024.0:F2} MB");
        Console.WriteLine($"✓ After retrieval: {afterRetrievalMemory / 1024.0 / 1024.0:F2} MB");
        Console.WriteLine($"✓ After GC: {finalMemory / 1024.0 / 1024.0:F2} MB");
        Console.WriteLine($"✓ Memory increase: {(afterLoggingMemory - initialMemory) / 1024.0 / 1024.0:F2} MB");

        Console.WriteLine("Memory tests completed! ✓");
    }

    public static void RunStressTests()
    {
        Console.WriteLine("Running Stress Tests...");
        Console.WriteLine("=====================");

        var logger = new LoggingService();
        var random = new Random();

        // Stress test with different log levels
        var stopwatch = System.Diagnostics.Stopwatch.StartNew();
        var tasks = new Task[20];

        for (int i = 0; i < tasks.Length; i++)
        {
            var threadId = i;
            tasks[i] = Task.Run(() =>
            {
                for (int j = 0; j < 500; j++)
                {
                    var logType = random.Next(4);
                    switch (logType)
                    {
                        case 0:
                            logger.LogInfo($"[Thread-{threadId}] Info message {j}");
                            break;
                        case 1:
                            logger.LogWarning($"[Thread-{threadId}] Warning message {j}");
                            break;
                        case 2:
                            logger.LogError($"[Thread-{threadId}] Error message {j}");
                            break;
                        case 3:
                            logger.LogDebug($"[Thread-{threadId}] Debug message {j}");
                            break;
                    }

                    // Occasionally retrieve logs
                    if (j % 50 == 0)
                    {
                        var recentLogs = logger.GetRecentLogs(10);
                    }
                }
            });
        }

        Task.WaitAll(tasks);
        stopwatch.Stop();

        Console.WriteLine($"✓ 10,000 concurrent log messages in {stopwatch.ElapsedMilliseconds}ms");
        Console.WriteLine($"✓ Average: {stopwatch.ElapsedMilliseconds / 10000.0:F2}ms per message");
        Console.WriteLine($"✓ Throughput: {10000.0 / stopwatch.Elapsed.TotalSeconds:F0} messages/second");

        // Verify log integrity
        var finalLogs = logger.GetRecentLogs(100);
        Console.WriteLine($"✓ Final log count: {finalLogs.Length}");
        Console.WriteLine("Stress tests completed! ✓");
    }
}
