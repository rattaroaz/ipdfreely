{
  "runtimeOptions": {
    "tfm": "net10.0",
    "frameworks": [
      {
        "name": "Microsoft.NETCore.App",
        "version": "10.0.2"
      },
      {
        "name": "Microsoft.Android",
        "version": "**FromWorkload**"
      },
      {
        "name": "Microsoft.Android.Runtimes",
        "version": "**FromWorkload**"
      }
